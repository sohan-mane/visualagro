# Copy to .env and fill in values

# SQLite (dev, default — no changes needed)
DATABASE_URL=sqlite:///./visualagro.db

# PostgreSQL (prod)
# DATABASE_URL=postgresql://user:password@localhost:5432/visualagro

# JWT — CHANGE THIS in production
SECRET_KEY=change-me-to-a-32-char-random-secret
TOKEN_EXPIRE_MINUTES=1440

# Redis (optional cache)
# REDIS_URL=redis://localhost:6379/0

# Phase 4 optional models
# YOLO_WEIGHTS_PATH=./models/yolov8_food.pt
# WHISPER_MODEL_SIZE=base
# EDGE_TTS_VOICE=en-IN-PrabhatNeural

# Voice / Vision optional models
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=hi
VISION_CAPTURE_INDEX=0